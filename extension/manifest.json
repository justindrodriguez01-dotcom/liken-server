{
  "manifest_version": 3,
  "name": "ColdMatch",
  "version": "1.0",
  "description": "Extracts name, headline, and location from LinkedIn profile pages.",
  "permissions": ["activeTab", "tabs", "scripting", "storage"],
  "options_page": "settings.html",
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://coldmatch.co/*",
    "https://liken-server-production.up.railway.app/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ColdMatch",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*", "https://linkedin.com/in/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}